# frozen_string_literal: true

source "https://rubygems.org"

# Specify your gem's dependencies in <%= config[:name] %>.gemspec
gemspec

gem "irb"
gem "rake", ">= 13.0"
<%- if config[:ext] -%>

gem "rake-compiler"
<%- end -%>
<%- if config[:test] -%>

gem "<%= config[:test] %>"
<%- end -%>
<%- if config[:linter] == "rubocop" -%>

gem "rubocop"
<%- elsif config[:linter] == "standard" -%>

gem "standard"
<%- end -%>
