BEGIN {
    @every = 1;
    @harness = 0;

    @gc_count = 0;
    @enable_print = 1;

    if (!@harness) {
        //always collect data
        @stats_enabled = 1;
    }

    printf("====RUBY_TRACING_LOG_START====\n");
}

% usdts.each do |probe, name, ph, niargs|
usdt:<%=ruby%>:ruby:<%=probe%> {
    if (@enable_print) {
        printf("<%=name%>,<%=ph%>,%d,%lu<%=",%lu"*niargs%>\n", tid, nsecs<%=(0...niargs).map{|i| ", arg#{i}"}.join%>);
    }
}
% end

// vim: ft=bpftrace ts=4 sw=4 sts=4 et
